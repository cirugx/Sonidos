# Configuración general del proyecto Paisaje Sonoro Desértico
# -----------------------------------------------------------------------------
# Este archivo se carga automáticamente al arrancar render.sh.
# Las variables de entorno tienen prioridad sobre este archivo.
# Para overrides locales sin tocar el repo, crea config/local.env (en .gitignore).

# ─── Parámetros de render ────────────────────────────────────────────────────
DURACION=10
SAMPLE_RATE=48000
BITS=24
# THREADS: comentado = autodetección con $(nproc). Descomenta para forzar:
# THREADS=4
FORMATO=wav

# ─── Diseño sónico: infrasonido y masa de aire ───────────────────────────────
INFRA_FREQ=19
INFRA_VOL=-22
INFRA_HARM2_VOL=-30
INFRA_HARM3_VOL=-36
ATMOS_FREQ=55
ATMOS_VOL=-12

# ─── Diseño sónico: materias primas ──────────────────────────────────────────
WIND_LP_FREQ=800
WIND_TREMOLO_FREQ=0.15
AGAVE_BP_FREQ=800
AGAVE_BP_WIDTH=3
SILICE_HP_FREQ=8000
SILICE_LP_FREQ=16000
SILICE_TREBLE_FREQ=12000
SILICE_TREBLE_GAIN=4

# ─── Diseño sónico: espacialización y sidechain ──────────────────────────────
CANON_DELAY_MS=240
SIDECHAIN_THRESH=-28
SIDECHAIN_RATIO=3

# ─── Mastering: target EBU R128 ──────────────────────────────────────────────
TARGET_LUFS=-16
TARGET_TP=-1.5
TARGET_LRA=11
